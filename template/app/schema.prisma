datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?     // You can delete this if you're not using Lemon Squeezy as your payments processor.
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  datePaid                  DateTime?
  credits                   Int             @default(3)

  gptResponses              GptResponse[]
  contactFormMessages       ContactFormMessage[]
  tasks                     Task[]
  files                     File[]
  technicians               Technician[]
  jobs                      Job[]
}

model GptResponse {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
}

model Task {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  description               String
  time                      String          @default("1")
  isDone                    Boolean         @default(false)
}

model File {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  type                      String
  s3Key                     String
}

model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

model ContactFormMessage {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  content                   String
  isRead                    Boolean         @default(false)
  repliedAt                 DateTime?
}

// Job costing: lets an account owner track true per-job profitability
// (revenue minus real labor and materials cost), not just revenue billed.
model Technician {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  name                      String
  // Fully burdened cost per hour to the business (wage + payroll tax + benefits/overhead),
  // not the rate billed to customers.
  hourlyCost                Float
  isActive                  Boolean         @default(true)

  laborEntries              LaborEntry[]
}

model Job {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  customerName              String
  address                   String?
  status                    String          @default("completed") // see JobStatus in src/job-costing/status.ts
  scheduledAt               DateTime?
  completedAt               DateTime?

  invoiceAmount             Float           @default(0) // total billed to the customer (revenue)

  lineItems                 JobLineItem[]
  laborEntries              LaborEntry[]
}

// A materials/parts cost line on a job. Snapshots unitCost at the time it's
// added so later price book changes don't retroactively change job history.
model JobLineItem {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  job                       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId                     String

  description               String
  quantity                  Float           @default(1)
  unitCost                  Float
}

// A technician's logged hours on a job. Snapshots the technician's hourly
// cost at the time of entry so later rate changes don't retroactively skew
// past job profitability.
model LaborEntry {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  job                       Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId                     String

  technician                Technician      @relation(fields: [technicianId], references: [id])
  technicianId              String

  hours                     Float
  hourlyCost                Float
}
